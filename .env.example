# Copy this file to .env and fill in values from your client.
# Never commit .env to git.

# Netrows (Twitter/X data) - https://netrows.com
NETROWS_API_KEY=

# Meta Graph API (Instagram) - https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=
# Optional: Instagram User ID from client (use as instagram_business_id for an athlete to enable Instagram data)
INSTAGRAM_USER_ID=

# NewsData.io (News) - https://newsdata.io
NEWSDATA_API_KEY=

# AWS Comprehend (Sentiment) - https://aws.amazon.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Supabase (Database) - https://supabase.com
SUPABASE_URL=
SUPABASE_KEY=

# Server
PORT=3000

# Optional: secret for HTTP-triggered daily cron (GET /api/cron/daily?secret=...). Set in production if using external cron.
CRON_SECRET=
